# ============================================================
# OpenClaw Gemma Pro - Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:27b
OLLAMA_LITE_MODEL=gemma4:4b
OLLAMA_TIMEOUT=120

# --- Memory ---
MEMORY_BASE_DIR=./memory
MAX_RAW_DAYS=30
# Max tokens to inject from memory into each live prompt
MAX_CONTEXT_TOKENS=4096

# --- Telegram Bot ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- WhatsApp (Twilio) ---
# From your Twilio console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Webhook Server ---
# URL your webhook server is publicly reachable at (for Telegram/WhatsApp callbacks)
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_PORT=8000

# --- Optional: Cloud Fallback (only if enabled in model-routing.json) ---
# OPENAI_API_KEY=sk-...

# --- Optional: Audio Transcription ---
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu

# --- Logging ---
LOG_LEVEL=INFO

