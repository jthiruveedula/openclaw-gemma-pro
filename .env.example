# ====================================================================
# OpenClaw Gemma Pro - Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ====================================================================

# ====================================================================
# Ollama Configuration (REQUIRED)
# ====================================================================
# Base URL for Ollama API
# Format: http://host:port or https://host:port
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model selection for different tiers
# PRO tier: Use larger, more capable models (e.g., gemma4:27b)
# Format: model_name:version
OLLAMA_MODEL=gemma4:27b

# LITE tier: Use smaller, faster models (e.g., gemma4:4b)
# Format: model_name:version
OLLAMA_LITE_MODEL=gemma4:4b

# Request timeout in seconds
# Range: 1-600
# Default: 300 - covers gemma4:27b cold-start on CPU-only hardware (can take 75-180s)
# NOTE: First request may take up to 3 min while Ollama loads the model into RAM.
# See: https://github.com/jthiruveedula/openclaw-gemma-pro/issues/6
OLLAMA_TIMEOUT=300

# ====================================================================
# Memory Configuration
# ====================================================================
# Base directory for memory storage
# Format: Absolute or relative path
# Example: ./memory or /var/app/memory
MEMORY_BASE_DIR=./memory

# Maximum days to retain memory data
# Range: 1-365
# Default: 30
MAX_RAW_DAYS=30

# Max tokens to inject from memory into each live prompt
# Range: 100-8000 (depends on model context window)
# Default: 2000
MAX_CONTEXT_TOKENS=4096

# ====================================================================
# Telegram Bot Configuration (OPTIONAL)
# ====================================================================
# Get your bot token from @BotFather on Telegram
# Format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Leave empty to disable Telegram integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ====================================================================
# WhatsApp (Twilio) Configuration (OPTIONAL)
# ====================================================================
# Get credentials from: https://console.twilio.com
# Account SID format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (34 chars)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token format: (32 character alphanumeric)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp number format: whatsapp:+14155238886
# IMPORTANT: +14155238886 is Twilio's sandbox test number. Replace with your
# production Twilio WhatsApp number before going live.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ====================================================================
# Webhook Server Configuration (OPTIONAL)
# ====================================================================
# Public URL where your webhook server is reachable
# Required for Telegram/WhatsApp callbacks
# Format: https://your-domain.com (must use HTTPS in production)
# Example: https://myapp.ngrok.io
WEBHOOK_BASE_URL=https://your-domain.com

# Webhook server port
# Range: 1024-65535 (avoid system ports 1-1023)
# Default: 8000
WEBHOOK_PORT=8000

# ====================================================================
# Optional: Cloud Fallback (Advanced)
# ====================================================================
# OpenAI API key for fallback when local model fails
# Format: sk-...
# Leave empty to disable cloud fallback
# OPENAI_API_KEY=sk-...

# ====================================================================
# Optional: Audio Transcription
# ====================================================================
# Enable audio transcription features
# Values: true, false
# Default: false
# ENABLE_AUDIO_TRANSCRIPTION=false
