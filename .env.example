# ====================================================================
# OpenClaw Gemma Pro - Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ====================================================================
# LEGEND: # REQUIRED = must be set before running
#         # OPTIONAL = leave empty/commented to disable feature
# ====================================================================

# ====================================================================
# Ollama Configuration (REQUIRED)
# ====================================================================
# Base URL for Ollama API
# Format: http://host:port or https://host:port
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434  # REQUIRED

# Model selection for different tiers
# PRO tier: Use larger, more capable models (e.g., gemma2:27b)
# Format: model_name:version
OLLAMA_MODEL=gemma2:27b  # REQUIRED

# LITE tier: Use smaller, faster models (e.g., gemma2:9b)
# Format: model_name:version
OLLAMA_LITE_MODEL=gemma2:9b  # REQUIRED

# Request timeout in seconds
# Range: 1-300 (recommended: 30-120 for gemma2:27b cold start may need 300)
# Default: 120 -- increase to 300 if you see timeout errors on cold start
OLLAMA_TIMEOUT=300  # REQUIRED

# ====================================================================
# Memory Configuration  # REQUIRED
# ====================================================================
# Base directory for memory storage
# Format: Absolute or relative path
# Example: ./memory or /var/app/memory
MEMORY_BASE_DIR=./memory  # REQUIRED

# Maximum days to retain memory data
# Range: 1-365
# Default: 30
MAX_RAW_DAYS=30  # REQUIRED

# Max tokens to inject from memory into each live prompt
# Range: 100-8000 (depends on model context window)
# Default: 2000
MAX_CONTEXT_TOKENS=4096  # REQUIRED

# ====================================================================
# Telegram Bot Configuration  # OPTIONAL
# ====================================================================
# Get your bot token from @BotFather on Telegram
# Format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Leave empty to disable Telegram integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here  # OPTIONAL

# ====================================================================
# WhatsApp (Twilio) Configuration  # OPTIONAL
# ====================================================================
# Get credentials from: https://console.twilio.com
# Account SID format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (34 chars)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # OPTIONAL

# Auth Token format: (32 character alphanumeric)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here  # OPTIONAL

# SANDBOX TEST NUMBER - Twilio's well-known WhatsApp sandbox number (+14155238886)
# !! REPLACE with your own Twilio WhatsApp Business number before going to production !!
# !! Using this sandbox number in production will cause message delivery failures !!
# Format: whatsapp:+<E.164 number>  e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+your_twilio_whatsapp_number_here  # OPTIONAL

# ====================================================================
# Webhook Server Configuration  # OPTIONAL
# ====================================================================
# Public URL where your webhook server is reachable
# Required for Telegram/WhatsApp callbacks
# Format: https://your-domain.com (must use HTTPS in production)
# Example: https://myapp.ngrok.io
WEBHOOK_BASE_URL=https://your-domain.com  # OPTIONAL

# Webhook server port
# Range: 1024-65535 (avoid system ports 1-1023)
# Default: 8000
WEBHOOK_PORT=8000  # OPTIONAL

# ====================================================================
# Cloud Fallback Configuration  # OPTIONAL (Advanced)
# ====================================================================
# OpenAI API key for fallback when local Ollama model fails
# Format: sk-...
# Leave empty/commented to disable OpenAI cloud fallback
# OPENAI_API_KEY=sk-your_openai_api_key_here  # OPTIONAL

# Cloud fallback provider: openai | gemini
# CLOUD_FALLBACK_PROVIDER=openai  # OPTIONAL

# Cloud fallback model (OpenAI: gpt-4o, Gemini: gemini-2.0-flash)
# CLOUD_FALLBACK_MODEL=gemini-2.0-flash  # OPTIONAL

# Google Gemini API key (for Gemini Flash fallback)
# GEMINI_API_KEY=your_gemini_api_key_here  # OPTIONAL

# ====================================================================
# Audio Transcription  # OPTIONAL
# ====================================================================
# Enable audio transcription features
# Values: true, false
# Default: false
# ENABLE_AUDIO_TRANSCRIPTION=false  # OPTIONAL
